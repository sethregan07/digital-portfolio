#Next
NEXT_PUBLIC_BASE_URL=https://localhost:3000

#Umami Analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

#Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

#Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

#Newsletter provider: mailerlite or listmonk
NEWSLETTER_PROVIDER=mailerlite

#MailerLite
# Default API base: https://connect.mailerlite.com/api/
EMAIL_API_BASE=
EMAIL_API_KEY=
# Comma-separated group IDs
EMAIL_LIST_UUIDS=

#Listmonk (optional alternative)
# EMAIL_API_BASE=https://list.yourdomain.com/
# EMAIL_LIST_UUIDS=uuid1,uuid2
# EMAIL_API_KEY=token api_user:token

#PostHog (heatmaps/session replay)
NEXT_PUBLIC_POSTHOG_KEY=
# Example: https://posthog.yourdomain.com
NEXT_PUBLIC_POSTHOG_HOST=

# Local build helper (skip DB queries)
SKIP_DB=false

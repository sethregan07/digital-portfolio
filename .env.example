#Next
NEXT_PUBLIC_BASE_URL=https://localhost:3000

#Umami Analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

#Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

#Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Newsletter provider: mailerlite or listmonk
NEWSLETTER_PROVIDER=mailerlite

#MailerLite
# Default API base: https://connect.mailerlite.com/api/
EMAIL_API_BASE=
EMAIL_API_KEY=
# Comma-separated group IDs
EMAIL_LIST_UUIDS=
# Optional alias map for product or sequence-specific groups
# Example: EMAIL_GROUP_MAP=newsletter:123456789,deprogramming:987654321,free-guide:555555555
EMAIL_GROUP_MAP=
# Optional provider-specific MailerLite settings when mixing providers
MAILERLITE_API_BASE=
MAILERLITE_API_KEY=
MAILERLITE_GROUP_IDS=
MAILERLITE_GROUP_MAP=

# Listmonk (optional alternative)
# Local default: http://localhost:9000/
# EMAIL_API_BASE=http://localhost:9000/
# EMAIL_LIST_UUIDS=uuid1,uuid2
# Optional for protected public subscriptions:
# EMAIL_API_KEY=token api_user:token
# Optional provider-specific Listmonk settings when mixing providers
LISTMONK_API_BASE=
LISTMONK_API_KEY=
LISTMONK_LIST_UUIDS=
LISTMONK_GROUP_MAP=

#PostHog (heatmaps/session replay)
NEXT_PUBLIC_POSTHOG_KEY=
# Example: https://posthog.yourdomain.com
NEXT_PUBLIC_POSTHOG_HOST=

# Local build helper (skip DB queries)
SKIP_DB=false
